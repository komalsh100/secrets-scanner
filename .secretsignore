# .secretsignore
# Add patterns here to exclude files/paths from scanning
# Supports glob patterns

# Test files
tests/*
*.test.py
*.spec.js
test_*.py

# Example and sample files
examples/*
sample/*
*.example
*.sample

# Documentation
docs/*
*.md

# CI/CD configs (managed secrets)
.github/*

# Dependencies
node_modules/*
vendor/*
venv/*
.venv/*

# Build artifacts
dist/*
build/*
__pycache__/*
*.pyc
